        local scrollPad = isMobile and 3 or 5

        local function addTooltip(el, tip)
            if not tip or tip=="" then return end
            if not isMobile then
                el.MouseEnter:Connect(function() showTooltip(tip, el) end)
                el.MouseLeave:Connect(function() hideTooltip() end)
            else
                local holding,holdTime,conn=false,0,nil
                el.InputBegan:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.Touch then
                        holding=true; holdTime=0
                        conn=RunService.RenderStepped:Connect(function(dt)
                            if holding then holdTime+=dt
                                if holdTime>=0.5 then showTooltip(tip,el); conn:Disconnect() end
                            end
                        end)
                    end
                end)
                el.InputEnded:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.Touch then
                        holding=false; if conn then conn:Disconnect() end; hideTooltip()
                    end
                end)
            end
        end

