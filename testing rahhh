                    Font=Enum.Font.GothamBold,TextSize=isMobile and 10 or 11,Parent=DHeader
                })

                local OptFrame=create("Frame",{
                    Name="Options",Size=UDim2.new(1,-10,1,-closedH-8),
                    Position=UDim2.new(0,5,0,closedH+4),BackgroundTransparency=1,Parent=DFrame
                })
                create("UIListLayout",{Padding=UDim.new(0,3),SortOrder=Enum.SortOrder.LayoutOrder,Parent=OptFrame})

                local checkmarks = {} -- optionName -> checkmark frame

                local function addOption(opt)
                    local OBtn=create("TextButton",{
                        Name=opt,Size=UDim2.new(1,0,0,optH),
                        BackgroundColor3=currentTheme.ButtonBg,Text="",AutoButtonColor=false,Parent=OptFrame
                    })
                    roundify(OBtn,6); registerThemedElement(OBtn,"BackgroundColor3","ButtonBg")
                    create("TextLabel",{
                        Size=UDim2.new(1,-35,1,0),Position=UDim2.new(0,10,0,0),
                        BackgroundTransparency=1,Text=opt,TextColor3=currentTheme.Text,
                        Font=Enum.Font.Gotham,TextSize=isMobile and 11 or 13,
                        TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=OBtn
                    })
                    local cSz2=isMobile and 16 or 18
                    local CK=create("TextLabel",{
                        Size=UDim2.new(0,cSz2,0,cSz2),
                        Position=UDim2.new(1,-(cSz2+6),0.5,-cSz2/2),
                        BackgroundColor3=currentTheme.ButtonBg,Text="",
                        TextColor3=Color3.fromRGB(255,255,255),Font=Enum.Font.GothamBold,
                        TextSize=isMobile and 11 or 13,Parent=OBtn
                    })
                    roundify(CK,4); addStroke(CK,currentTheme.Border,1)
                    checkmarks[opt]=CK

                    if isMobile then
                        OBtn.MouseButton1Down:Connect(function() OBtn.BackgroundColor3=currentTheme.ButtonHover end)
                        OBtn.MouseButton1Up:Connect(function() OBtn.BackgroundColor3=currentTheme.ButtonBg end)
                    else
                        OBtn.MouseEnter:Connect(function() tween(OBtn,{BackgroundColor3=currentTheme.ButtonHover},0.2) end)
                        OBtn.MouseLeave:Connect(function() tween(OBtn,{BackgroundColor3=currentTheme.ButtonBg},0.2) end)
                    end

                    OBtn.MouseButton1Click:Connect(function()
                        if selected[opt] then
                            selected[opt]=nil; CK.Text=""
                            tween(CK,{BackgroundColor3=currentTheme.ButtonBg},0.2)
                            for _,c in pairs(CK:GetChildren()) do if c:IsA("UIGradient") then c:Destroy() end end
                        else
                            selected[opt]=true; CK.Text="✓"
                            tween(CK,{BackgroundColor3=currentTheme.Accent},0.2)
                            addGradient(CK,{currentTheme.Accent,currentTheme.AccentSecondary},45)
                        end
                        if callback then pcall(function() callback(selected) end) end
                    end)
                end

                for _,opt in ipairs(options) do addOption(opt) end

                DHeader.MouseButton1Click:Connect(function()
                    isOpen=not isOpen
                    if isOpen then tween(DFrame,{Size=UDim2.new(1,-10,0,openH)},0.3); tween(DArrow,{Rotation=180},0.3)
                    else tween(DFrame,{Size=UDim2.new(1,-10,0,closedH)},0.3); tween(DArrow,{Rotation=0},0.3) end
                end)

                local function clearSelection()
                    for opt,_ in pairs(selected) do
                        selected[opt]=nil
                        if checkmarks[opt] then
                            checkmarks[opt].Text=""
                            tween(checkmarks[opt],{BackgroundColor3=currentTheme.ButtonBg},0.2)
                            for _,c in pairs(checkmarks[opt]:GetChildren()) do if c:IsA("UIGradient") then c:Destroy() end end
                        end
                    end
                end

                local function setSelected(opts)
                    clearSelection()
                    if type(opts)=="table" then
                        for _,opt in ipairs(opts) do
                            if checkmarks[opt] then
                                selected[opt]=true
                                checkmarks[opt].Text="✓"
                                tween(checkmarks[opt],{BackgroundColor3=currentTheme.Accent},0.2)
                                addGradient(checkmarks[opt],{currentTheme.Accent,currentTheme.AccentSecondary},45)
                            end
                        end
                    end
                    if callback then pcall(function() callback(selected) end) end
                end

                local function getSelected()
                    local arr={}
                    for opt,_ in pairs(selected) do arr[#arr+1]=opt end
                    return arr
                end

                local api={
                    Frame        = DFrame,
                    GetSelected  = getSelected,
                    GetValue     = getSelected,
                    SetSelected  = setSelected,
                    SetValue     = setSelected,
                    ClearSelected= clearSelection,
                    AddOption    = function(opt)
                        table.insert(options,opt)
                        addOption(opt)
                        openH = closedH + (#options*(optH+3)) + 8
                    end,
                    Show         = function() DFrame.Visible=true end,
                    Hide         = function() DFrame.Visible=false end,
                    SetCallback  = function(fn) callback=fn end,
                }
                local sk=saveKey or dname
                registerElement(sk, api)
                registerSaveable(sk, getSelected, setSelected)
                return api
            end

