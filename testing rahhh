    ---[[
        Batch set values.
        Example:
            Window:SetValues({
                ["Speed Boost"] = true,
                ["Walk Speed"]  = 50,
                ["Team"]        = {"Blue"},
            })
    ]]
    function Window:SetValues(tbl)
        for name, value in pairs(tbl) do
            local el = self.ElementRegistry[name]
            if el and el.SetValue then pcall(el.SetValue, value) end
        end
    end

    ---[[
        SaveConfig / LoadConfig / AutoSave
        Uses writefile / readfile (executor APIs).
        Falls back gracefully if unavailable.
        
        Example:
            Window:SaveConfig()               -- saves to "MyScript_config.json"
            Window:SaveConfig("custom.json")
            local ok = Window:LoadConfig()
            Window:AutoSave(30)               -- auto-save every 30 s
    ]]
    function Window:SaveConfig(filename)
        filename = filename or saveFile
        local data = {}
        for key, reg in pairs(self.SaveRegistry) do
            pcall(function() data[key] = reg.GetValue() end)
        end
        local ok, json = pcall(HttpService.JSONEncode, HttpService, data)
        if not ok then
            warn("UILibrary: SaveConfig encode failed:", json)
            return false
        end
        local ok2, err = pcall(writefile, filename, json)
        if ok2 then
            return true, filename
        else
            warn("UILibrary: SaveConfig write failed (writefile unavailable?):", err)
            return false
        end
    end

    function Window:LoadConfig(filename)
        filename = filename or saveFile
        local ok1, content = pcall(readfile, filename)
        if not ok1 then return false, "File not found: "..filename end
        local ok2, data = pcall(HttpService.JSONDecode, HttpService, content)
        if not ok2 then return false, "Parse error" end
        for key, value in pairs(data) do
            if self.SaveRegistry[key] then
                pcall(self.SaveRegistry[key].SetValue, value)
            end
        end
        return true
    end

    function Window:AutoSave(interval, filename)
        interval = math.max(interval or 30, 5)
        task.spawn(function()
            while ScreenGui and ScreenGui.Parent do
                task.wait(interval)
                self:SaveConfig(filename)
            end
        end)
    end

