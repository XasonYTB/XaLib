    local Window = {
        Categories       = {},
        CurrentCategory  = nil,
        SearchableElements = {},
        DependencyMap    = {},
        ThemedElements   = {},
        ElementRegistry  = {},  -- name → API object
        SaveRegistry     = {},  -- key  → {GetValue, SetValue}
        Flags            = {}   -- proxy table (set up below)
    }

    -- Flags proxy: Window.Flags["Name"] returns/sets values
    setmetatable(Window.Flags, {
        __index = function(_, key)
            local el = Window.ElementRegistry[key]
            if el and el.GetValue then return el.GetValue() end
            return nil
        end,
        __newindex = function(_, key, value)
            local el = Window.ElementRegistry[key]
            if el and el.SetValue then pcall(el.SetValue, value) end
        end
    })

    --// Internal helpers
    local function registerThemedElement(el, prop, key)
        table.insert(Window.ThemedElements, {Element=el, Property=prop, ThemeKey=key})
    end

    local function registerDependency(el, dependsOn, cond)
        if not Window.DependencyMap[dependsOn] then Window.DependencyMap[dependsOn]={} end
        table.insert(Window.DependencyMap[dependsOn], {Element=el, Condition=cond or function(v) return v end})
    end

    local function updateDependents(srcId, value)
        local list = Window.DependencyMap[srcId]
        if not list then return end
        for _, dep in ipairs(list) do
            if dep.Element and dep.Element.Parent then
                dep.Element.Visible = dep.Condition(value)
            end
        end
    end

    local function registerElement(name, api)
        -- store in registry (last write wins for duplicate names)
        Window.ElementRegistry[name] = api
        table.insert(Window.SearchableElements, {Name=name, Object=api.Frame})
    end

    local function registerSaveable(key, getVal, setVal)
        Window.SaveRegistry[key] = {GetValue=getVal, SetValue=setVal}
    end

    --// Theme
    local function applyTheme(name)
        if not Themes[name] then return end
        currentTheme = Themes[name]
        Container.BackgroundColor3 = currentTheme.Background
        containerStroke.Color      = currentTheme.Border
        Sidebar.BackgroundColor3   = currentTheme.Sidebar
        TooltipFrame.BackgroundColor3 = currentTheme.Tooltip
        tooltipStroke.Color        = currentTheme.Accent
        TooltipText.TextColor3     = currentTheme.Text
        addGradient(Header,    {currentTheme.Accent, currentTheme.AccentSecondary}, 45)
        addGradient(ToggleBtn, {currentTheme.Accent, currentTheme.AccentSecondary}, 45)
        for _, t in ipairs(Window.ThemedElements) do
            if t.Element and t.Element.Parent then
                pcall(function() t.Element[t.Property] = currentTheme[t.ThemeKey] end)
            end
        end
        for _, cb in ipairs(themeChangedCallbacks) do pcall(cb, currentTheme) end
    end

    function Window:SetTheme(n) applyTheme(n) end
    function Window:GetThemes()
        local out={}; for n in pairs(Themes) do out[#out+1]=n end; return out
    end
    function Window:OnThemeChanged(cb) table.insert(themeChangedCallbacks, cb) end

