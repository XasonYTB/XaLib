                    Font=Enum.Font.GothamSemibold,TextSize=isMobile and 12 or 14,
                    TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=KFrame
                })

                local KBtn=create("TextButton",{
                    Size=UDim2.new(0,isMobile and 70 or 80,0,isMobile and 26 or 28),
                    Position=UDim2.new(1,-(isMobile and 78 or 88),0.5,-(isMobile and 13 or 14)),
                    BackgroundColor3=currentTheme.ButtonBg,
                    Text=currentKey and getKeyName(currentKey) or "None",
                    TextColor3=currentTheme.Accent,Font=Enum.Font.GothamBold,
                    TextSize=isMobile and 11 or 12,AutoButtonColor=false,Parent=KFrame
                })
                roundify(KBtn,6); addStroke(KBtn,currentTheme.Border,1)
                registerThemedElement(KBtn,"BackgroundColor3","ButtonBg")
                registerThemedElement(KBtn,"TextColor3","Accent")

                local inputConn
                KBtn.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening=true; KBtn.Text="..."
                    tween(KBtn,{BackgroundColor3=currentTheme.Accent},0.2)
                    KBtn.TextColor3=Color3.fromRGB(255,255,255)
                    inputConn=UserInputService.InputBegan:Connect(function(inp,_gp)
                        if inp.UserInputType==Enum.UserInputType.Keyboard then
                            inputConn:Disconnect(); listening=false
                            currentKey = inp.KeyCode==Enum.KeyCode.Escape and nil or inp.KeyCode
                            KBtn.Text = currentKey and getKeyName(currentKey) or "None"
                            tween(KBtn,{BackgroundColor3=currentTheme.ButtonBg},0.2)
                            KBtn.TextColor3=currentTheme.Accent
                            if callback then pcall(function() callback(currentKey) end) end
                        end
                    end)
                end)

                UserInputService.InputBegan:Connect(function(inp,gp)
                    if not gp and not listening and currentKey and inp.KeyCode==currentKey then
                        if callback then pcall(function() callback(currentKey,true) end) end
                    end
                end)

                local api={
                    Frame    = KFrame,
                    GetKey   = function() return currentKey end,
                    GetValue = function() return currentKey and currentKey.Name or nil end,
                    SetKey   = function(kc) currentKey=kc; KBtn.Text=kc and getKeyName(kc) or "None" end,
                    SetValue = function(name)
                        local kc=keyCodeFromName(name)
                        currentKey=kc; KBtn.Text=kc and getKeyName(kc) or "None"
                        if kc and callback then pcall(function() callback(kc) end) end
                    end,
                    Show     = function() KFrame.Visible=true end,
                    Hide     = function() KFrame.Visible=false end,
                    SetCallback=function(fn) callback=fn end,
                }
                local sk=saveKey or kname
                registerElement(sk, api)
                registerSaveable(sk,
                    function() return currentKey and currentKey.Name or nil end,
                    function(v) api.SetValue(v) end
                )
                return api
            end

            --// DROPDOWN
            function E:Dropdown(dname, options, callback, tip, saveKey)
