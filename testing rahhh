--// Helpers
local function create(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then obj[k] = v end
    end
    if props.Parent then obj.Parent = props.Parent end
    return obj
end

local function roundify(obj, r)
    create("UICorner", { CornerRadius = UDim.new(0, r or 4), Parent = obj })
end

local function addStroke(obj, color, thickness)
    return create("UIStroke", {
        Color = color or currentTheme.Border,
        Thickness = thickness or 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = obj
    })
end

local function addGradient(obj, colors, rotation)
    for _, c in ipairs(obj:GetChildren()) do
        if c:IsA("UIGradient") then c:Destroy() end
    end
    local kp = {}
    for i, col in ipairs(colors) do
        kp[#kp+1] = ColorSequenceKeypoint.new((i-1)/(#colors-1), col)
    end
    create("UIGradient", {
        Color = ColorSequence.new(kp),
        Rotation = rotation or 0,
        Parent = obj
    })
end

local function tween(obj, props, dur, style, dir)
    local tw = TweenService:Create(obj,
        TweenInfo.new(dur or 0.3, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props)
    tw:Play()
    return tw
end

local function getMobileSize()
    local cam = workspace.CurrentCamera
    if not cam then return Vector2.new(700,500) end
    local vp = cam.ViewportSize
    if isMobile then
        return Vector2.new(math.min(vp.X*0.95,450), math.min(vp.Y*0.85,600))
    elseif isTablet then
        return Vector2.new(math.min(vp.X*0.8,600), math.min(vp.Y*0.75,550))
    end
    return Vector2.new(700,500)
end

local function getKeyName(keyCode)
    if not keyCode then return "None" end
    local clean = {
        LeftShift="LShift", RightShift="RShift", LeftControl="LCtrl",
        RightControl="RCtrl", LeftAlt="LAlt", RightAlt="RAlt",
        Backquote="`", Minus="-", Equals="=", LeftBracket="[",
        RightBracket="]", Backslash="\\", Semicolon=";", Quote="'",
        Comma=",", Period=".", Slash="/", Space="Space",
        Return="Enter", Escape="Esc"
    }
    return clean[keyCode.Name] or keyCode.Name
end

-- Attempt to find a KeyCode by name string (for save/load)
local function keyCodeFromName(name)
    if not name then return nil end
    local ok, kc = pcall(function() return Enum.KeyCode[name] end)
    return ok and kc or nil
end

