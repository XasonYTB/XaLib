--// Resolve LocalPlayer
local player = Players.LocalPlayer
do
    local retries = 0
    while not player and retries < 10 do
        player = Players.LocalPlayer
        if not player then task.wait(0.1) end
        retries = retries + 1
    end
    if not player then
        warn("UILibrary: Failed to get LocalPlayer")
        return UILibrary
    end
end

local playerGui = player:WaitForChild("PlayerGui", 10)
if not playerGui then
    warn("UILibrary: Failed to get PlayerGui")
    return UILibrary
end

