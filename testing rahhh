        ------------------------------------------------------------------
        -- CATEGORY OBJECT
        ------------------------------------------------------------------
        local Category = {}
        Category.ScrollFrame=ScrollFrame
        Category.Tabs=catData.Tabs

        function Category:CreateTab(tabName, icon)
            if #catData.Tabs==0 then
                TabHeader.Visible=true; TabContent.Visible=true; ScrollFrame.Visible=false
            end
            local tabData={Name=tabName, Icon=icon or "📄"}

            local TabBtn=create("TextButton",{
                Name=tabName,Size=UDim2.new(0,isMobile and 70 or 90,1,0),
                BackgroundColor3=currentTheme.ButtonBg,Text="",AutoButtonColor=false,Parent=TabHeader
            })
            roundify(TabBtn,6); registerThemedElement(TabBtn,"BackgroundColor3","ButtonBg")

            local TabLbl=create("TextLabel",{
                Size=UDim2.new(1,-8,1,0),Position=UDim2.new(0,4,0,0),
                BackgroundTransparency=1,Text=(icon or "📄").." "..tabName,
                TextColor3=currentTheme.TextDim,Font=Enum.Font.GothamSemibold,
                TextSize=isMobile and 10 or 12,TextWrapped=true,Parent=TabBtn
            })
            registerThemedElement(TabLbl,"TextColor3","TextDim")

            local TabScroll=create("ScrollingFrame",{
                Name=tabName.."Content",Size=UDim2.new(1,0,1,0),
                BackgroundTransparency=1,BorderSizePixel=0,
                ScrollBarThickness=isMobile and 4 or 5,
                ScrollBarImageColor3=currentTheme.Accent,
                CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
                Visible=false,Parent=TabContent
            })
            registerThemedElement(TabScroll,"ScrollBarImageColor3","Accent")
            create("UIListLayout",{Padding=UDim.new(0,isMobile and 8 or 10),SortOrder=Enum.SortOrder.LayoutOrder,Parent=TabScroll})
            create("UIPadding",{PaddingLeft=UDim.new(0,scrollPad),PaddingRight=UDim.new(0,isMobile and 8 or 10),Parent=TabScroll})

            tabData.ScrollFrame=TabScroll; tabData.Button=TabBtn; tabData.Label=TabLbl

            TabBtn.MouseButton1Click:Connect(function()
                for _,t in pairs(catData.Tabs) do
                    t.ScrollFrame.Visible=false; t.Button.BackgroundColor3=currentTheme.ButtonBg; t.Label.TextColor3=currentTheme.TextDim
                end
                TabScroll.Visible=true; TabBtn.BackgroundColor3=currentTheme.Panel
                TabLbl.TextColor3=currentTheme.Accent; catData.CurrentTab=tabData
            end)
            if isMobile then
                TabBtn.MouseButton1Down:Connect(function() if catData.CurrentTab~=tabData then TabBtn.BackgroundColor3=currentTheme.Panel end end)
            else
                TabBtn.MouseEnter:Connect(function() if catData.CurrentTab~=tabData then tween(TabBtn,{BackgroundColor3=currentTheme.Panel},0.2) end end)
                TabBtn.MouseLeave:Connect(function() if catData.CurrentTab~=tabData then tween(TabBtn,{BackgroundColor3=currentTheme.ButtonBg},0.2) end end)
            end

            table.insert(catData.Tabs, tabData)
            if #catData.Tabs==1 then
                TabScroll.Visible=true; TabBtn.BackgroundColor3=currentTheme.Panel
                TabLbl.TextColor3=currentTheme.Accent; catData.CurrentTab=tabData
            end

            return makeElements(TabScroll)
        end

        -- Attach default (no-tab) element factory to Category
        local catElements = makeElements(ScrollFrame)
        for k,v in pairs(catElements) do Category[k]=v end

        return Category
    end -- CreateCategory

    return Window
end -- CreateWindow

