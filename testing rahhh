                    BackgroundColor3=currentTheme.Accent,BorderSizePixel=0,Parent=SBar
                })
                roundify(SFill,bH2/2)
                addGradient(SFill,{currentTheme.Accent,currentTheme.AccentSecondary},45)

                local _dragging=false
                local function updateFromInput(inp)
                    local pos=math.clamp((inp.Position.X-SBar.AbsolutePosition.X)/SBar.AbsoluteSize.X,0,1)
                    value=math.floor(smin+(smax-smin)*pos)
                    SVal.Text=tostring(value)
                    SFill.Size=UDim2.new(pos,0,1,0)
                    if callback then pcall(function() callback(value) end) end
                end

                SBar.InputBegan:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
                        _dragging=true; updateFromInput(inp)
                    end
                end)
                UserInputService.InputEnded:Connect(function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
                        _dragging=false
                    end
                end)
                UserInputService.InputChanged:Connect(function(inp)
                    if _dragging and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
                        updateFromInput(inp)
                    end
                end)

                local function setVal(v, silent)
                    value=math.clamp(math.floor(v), smin, smax)
                    SVal.Text=tostring(value)
                    local pos=(value-smin)/(smax-smin)
                    tween(SFill,{Size=UDim2.new(pos,0,1,0)},0.15)
                    if not silent and callback then pcall(function() callback(value) end) end
                end

                local api={
                    Frame       = SFrame,
                    GetValue    = function() return value end,
                    SetValue    = function(v) setVal(v, false) end,
                    SetMin      = function(m) smin=m; setVal(value,true) end,
                    SetMax      = function(m) smax=m; setVal(value,true) end,
                    Show        = function() SFrame.Visible=true end,
                    Hide        = function() SFrame.Visible=false end,
                    SetCallback = function(fn) callback=fn end,
                }
                local sk=saveKey or sname
                registerElement(sk, api)
                registerSaveable(sk, function() return value end, function(v) setVal(v, false) end)
                return api
            end

