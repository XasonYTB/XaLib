                    Font=Enum.Font.GothamSemibold,TextSize=isMobile and 12 or 14,
                    TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,Parent=HBtn
                })
                local SCArrow=create("TextLabel",{
                    Size=UDim2.new(0,20,0,20),Position=UDim2.new(1,-30,0.5,-10),
                    BackgroundTransparency=1,Text="▼",TextColor3=currentTheme.Accent,
                    Font=Enum.Font.GothamBold,TextSize=isMobile and 10 or 11,
                    Rotation=scOpen and 0 or -90,Parent=HBtn
                })
                registerThemedElement(SCArrow,"TextColor3","Accent")

                local SCContent=create("Frame",{
                    Name="Content",Size=UDim2.new(1,-10,0,0),
                    Position=UDim2.new(0,5,0,closedH),BackgroundTransparency=1,Parent=SCFrame
                })
                local SCLayout=create("UIListLayout",{
                    Padding=UDim.new(0,isMobile and 6 or 8),SortOrder=Enum.SortOrder.LayoutOrder,Parent=SCContent
                })
                create("UIPadding",{PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,8),Parent=SCContent})

                local function scUpdateSize()
                    local ch=SCLayout.AbsoluteContentSize.Y+12
                    local th=scOpen and (closedH+ch) or closedH
