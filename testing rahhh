            --// SUBCATEGORY
            function E:SubCategory(scname, icon, defaultOpen)
                local scOpen = defaultOpen or false
                local closedH=isMobile and 36 or 40

                local SCFrame=create("Frame",{
                    Name="SubCat_"..scname,Size=UDim2.new(1,-10,0,closedH),
