    --// Resize Handles
    local resizing,resizeDir,resizeStart,startSz,startPs = false,nil,nil,nil,nil
    local function makeResizeHandle(name, pos)
        local h = create("TextButton", {
            Name=name, Size=UDim2.new(0,12,0,12), Position=pos,
            BackgroundTransparency=1, Text="", AutoButtonColor=false, ZIndex=100, Parent=Container
        })
        h.InputBegan:Connect(function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
                resizing=true; resizeDir=name; resizeStart=inp.Position
                startSz=Vector2.new(Container.Size.X.Offset,Container.Size.Y.Offset)
                startPs=Vector2.new(Container.Position.X.Offset,Container.Position.Y.Offset)
            end
        end)
    end
    makeResizeHandle("BottomRight",UDim2.new(1,-12,1,-12))
    makeResizeHandle("BottomLeft", UDim2.new(0,0,1,-12))
    makeResizeHandle("TopRight",   UDim2.new(1,-12,0,0))
    makeResizeHandle("TopLeft",    UDim2.new(0,0,0,0))
    makeResizeHandle("Right",      UDim2.new(1,-6,0.5,-6))
    makeResizeHandle("Left",       UDim2.new(0,-6,0.5,-6))
    makeResizeHandle("Bottom",     UDim2.new(0.5,-6,1,-6))
    makeResizeHandle("Top",        UDim2.new(0.5,-6,0,-6))

    UserInputService.InputChanged:Connect(function(inp)
        if resizing and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
            local d = inp.Position - resizeStart
            local nw,nh,nx,ny = startSz.X,startSz.Y,startPs.X,startPs.Y
            local function clampW(v) return math.clamp(v,minSize.X,maxSize.X) end
            local function clampH(v) return math.clamp(v,minSize.Y,maxSize.Y) end
            if resizeDir=="BottomRight" then nw=clampW(startSz.X+d.X); nh=clampH(startSz.Y+d.Y)
            elseif resizeDir=="BottomLeft" then local wc=clampW(startSz.X-d.X)-startSz.X; nw=startSz.X+wc; nx=startPs.X-wc; nh=clampH(startSz.Y+d.Y)
            elseif resizeDir=="TopRight" then nw=clampW(startSz.X+d.X); local hc=clampH(startSz.Y-d.Y)-startSz.Y; nh=startSz.Y+hc; ny=startPs.Y-hc
            elseif resizeDir=="TopLeft" then local wc=clampW(startSz.X-d.X)-startSz.X; nw=startSz.X+wc; nx=startPs.X-wc; local hc=clampH(startSz.Y-d.Y)-startSz.Y; nh=startSz.Y+hc; ny=startPs.Y-hc
            elseif resizeDir=="Right" then nw=clampW(startSz.X+d.X)
            elseif resizeDir=="Left" then local wc=clampW(startSz.X-d.X)-startSz.X; nw=startSz.X+wc; nx=startPs.X-wc
            elseif resizeDir=="Bottom" then nh=clampH(startSz.Y+d.Y)
            elseif resizeDir=="Top" then local hc=clampH(startSz.Y-d.Y)-startSz.Y; nh=startSz.Y+hc; ny=startPs.Y-hc
            end
            Container.Size=UDim2.new(0,nw,0,nh); Container.Position=UDim2.new(0.5,nx,0.5,ny)
