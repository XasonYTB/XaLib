					Position = UDim2.new(1, -(isMobile and 78 or 88), 0.5, -(isMobile and 13 or 14)),
					BackgroundColor3 = currentTheme.ButtonBg,
					Text = currentKey and getKeyName(currentKey) or "None",
					TextColor3 = currentTheme.Accent,
					Font = Enum.Font.GothamBold,
					TextSize = isMobile and 11 or 12,
					AutoButtonColor = false,
					Parent = KeybindFrame
				})
				roundify(KeyButton, 6)
				addStroke(KeyButton, currentTheme.Border, 1)
				registerThemedElement(KeyButton, "BackgroundColor3", "ButtonBg")
				registerThemedElement(KeyButton, "TextColor3", "Accent")

				local inputConnection

				KeyButton.MouseButton1Click:Connect(function()
					if listening then return end

					listening = true
					KeyButton.Text = "..."
					tween(KeyButton, {BackgroundColor3 = currentTheme.Accent}, 0.2)
					KeyButton.TextColor3 = Color3.fromRGB(255, 255, 255)

					inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
						if input.UserInputType == Enum.UserInputType.Keyboard then
							inputConnection:Disconnect()
							listening = false

							if input.KeyCode == Enum.KeyCode.Escape then
								currentKey = nil
								KeyButton.Text = "None"
							else
								currentKey = input.KeyCode
								KeyButton.Text = getKeyName(currentKey)
							end

							tween(KeyButton, {BackgroundColor3 = currentTheme.ButtonBg}, 0.2)
							KeyButton.TextColor3 = currentTheme.Accent

							if callback then
								pcall(function()
									callback(currentKey)
								end)
							end
						end
					end)
				end)

				-- Listen for keybind activation
				UserInputService.InputBegan:Connect(function(input, gameProcessed)
					if not gameProcessed and not listening and currentKey and input.KeyCode == currentKey then
						if callback then
							pcall(function()
								callback(currentKey, true) -- Second param indicates key was pressed
							end)
						end
					end
				end)

				local KeybindAPI = {}

				function KeybindAPI:SetKey(key)
					currentKey = key
					KeyButton.Text = key and getKeyName(key) or "None"
				end

				function KeybindAPI:GetKey()
					return currentKey
				end

				return KeybindFrame, KeybindAPI
			end

