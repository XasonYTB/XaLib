	--// Dependency System
	local function registerDependency(element, dependsOn, condition)
		if not Window.DependencyMap[dependsOn] then
			Window.DependencyMap[dependsOn] = {}
		end
		table.insert(Window.DependencyMap[dependsOn], {
			Element = element,
			Condition = condition or function(value) return value end
		})
	end

	local function updateDependents(sourceId, value)
		if Window.DependencyMap[sourceId] then
			for _, dep in ipairs(Window.DependencyMap[sourceId]) do
				if dep.Element and dep.Element.Parent then
					local shouldShow = dep.Condition(value)
					dep.Element.Visible = shouldShow
				end
			end
		end
	end

	--// Theme System Functions
	local function registerThemedElement(element, colorProperty, themeKey)
		table.insert(Window.ThemedElements, {
			Element = element,
			Property = colorProperty,
			ThemeKey = themeKey
		})
	end

	local function applyTheme(themeName)
		if not Themes[themeName] then return end

		currentTheme = Themes[themeName]

		-- Update main elements
		Container.BackgroundColor3 = currentTheme.Background
		containerStroke.Color = currentTheme.Border
		Sidebar.BackgroundColor3 = currentTheme.Sidebar
		TooltipFrame.BackgroundColor3 = currentTheme.Tooltip
		tooltipStroke.Color = currentTheme.Accent
		TooltipText.TextColor3 = currentTheme.Text

		-- Update header gradient
		addGradient(Header, {currentTheme.Accent, currentTheme.AccentSecondary}, 45)
		addGradient(ToggleBtn, {currentTheme.Accent, currentTheme.AccentSecondary}, 45)

		-- Update all registered themed elements
		for _, themed in ipairs(Window.ThemedElements) do
			if themed.Element and themed.Element.Parent then
				pcall(function()
					themed.Element[themed.Property] = currentTheme[themed.ThemeKey]
				end)
			end
		end

		-- Fire theme change callbacks
		for _, callback in ipairs(themeChangedCallbacks) do
			pcall(callback, currentTheme)
		end
	end

	function Window:SetTheme(themeName)
		applyTheme(themeName)
	end

	function Window:GetThemes()
		local themeNames = {}
		for name, _ in pairs(Themes) do
			table.insert(themeNames, name)
		end
		return themeNames
	end

	function Window:OnThemeChanged(callback)
		table.insert(themeChangedCallbacks, callback)
	end

