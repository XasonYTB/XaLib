		Name = "ModernUI_" .. title,
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		IgnoreGuiInset = true,
		Parent = playerGui
	})

	--// Tooltip Container (Top Level)
	local TooltipFrame = create("Frame", {
		Name = "Tooltip",
		Size = UDim2.new(0, 200, 0, 0),
		Position = UDim2.new(0, 0, 0, 0),
		BackgroundColor3 = currentTheme.Tooltip,
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 10000,
		Parent = ScreenGui
	})
	roundify(TooltipFrame, 6)
	local tooltipStroke = addStroke(TooltipFrame, currentTheme.Accent, 1.5)

	local TooltipText = create("TextLabel", {
		Size = UDim2.new(1, -16, 1, -8),
		Position = UDim2.new(0, 8, 0, 4),
		BackgroundTransparency = 1,
		Text = "",
		TextColor3 = currentTheme.Text,
		Font = Enum.Font.Gotham,
		TextSize = isMobile and 11 or 12,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Top,
		TextWrapped = true,
		Parent = TooltipFrame
	})

	local function showTooltip(text, targetObj)
		if not text or text == "" then return end

		TooltipText.Text = text
		local textSize = game:GetService("TextService"):GetTextSize(
			text,
			TooltipText.TextSize,
			TooltipText.Font,
			Vector2.new(250, math.huge)
		)

		local tooltipWidth = math.min(math.max(textSize.X + 16, 120), 280)
		local tooltipHeight = textSize.Y + 12

		TooltipFrame.Size = UDim2.new(0, tooltipWidth, 0, tooltipHeight)
		TooltipFrame.Visible = true

		local function updatePosition()
			if not targetObj or not targetObj.Parent then
				TooltipFrame.Visible = false
				return
			end

			local mousePos = UserInputService:GetMouseLocation()
			local offsetX = 12
			local offsetY = 12

			TooltipFrame.Position = UDim2.new(0, mousePos.X + offsetX, 0, mousePos.Y + offsetY)
		end

		updatePosition()

		local connection
		connection = RunService.RenderStepped:Connect(function()
			if TooltipFrame.Visible then
				updatePosition()
			else
				connection:Disconnect()
			end
		end)
	end

	local function hideTooltip()
		TooltipFrame.Visible = false
	end

	--// Invisible Modal Button
	local ModalBtn = create("TextButton", {
		Name = "ModalButton",
		Size = UDim2.new(0, 0, 0, 0),
		Position = UDim2.new(0, 0, 0, 0),
		BackgroundTransparency = 1,
		Text = "",
		Modal = true,
		Visible = false,
		Parent = ScreenGui
	})

	--// Main Container
	local Container = create("Frame", {
		Name = "Container",
		Size = UDim2.new(0, size.X, 0, size.Y),
		Position = UDim2.new(0.5, -size.X/2, 0.5, -size.Y/2),
		BackgroundColor3 = currentTheme.Background,
		BorderSizePixel = 0,
		Visible = false,
		Parent = ScreenGui
	})
	roundify(Container, isMobile and 16 or 12)
	local containerStroke = addStroke(Container, currentTheme.Border, 1.5)

	--// Resize Handles
	local resizeHandleSize = 12
	local resizing = false
	local resizeDir = nil
	local resizeStart = nil
	local startSize = nil
	local startPos = nil

	local function createResizeHandle(name, position, cursor)
		local handle = create("TextButton", {
			Name = name,
			Size = UDim2.new(0, resizeHandleSize, 0, resizeHandleSize),
			Position = position,
			BackgroundTransparency = 1,
			Text = "",
			AutoButtonColor = false,
			ZIndex = 100,
			Parent = Container
		})

		handle.MouseEnter:Connect(function()
			-- Could change cursor here if we had cursor support
		end)

		handle.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				resizing = true
				resizeDir = name
				resizeStart = input.Position
				startSize = Vector2.new(Container.Size.X.Offset, Container.Size.Y.Offset)
				startPos = Vector2.new(Container.Position.X.Offset, Container.Position.Y.Offset)
			end
		end)

		return handle
	end

	-- Corner handles
	createResizeHandle("BottomRight", UDim2.new(1, -resizeHandleSize, 1, -resizeHandleSize))
	createResizeHandle("BottomLeft", UDim2.new(0, 0, 1, -resizeHandleSize))
	createResizeHandle("TopRight", UDim2.new(1, -resizeHandleSize, 0, 0))
	createResizeHandle("TopLeft", UDim2.new(0, 0, 0, 0))

	-- Edge handles
	createResizeHandle("Right", UDim2.new(1, -resizeHandleSize/2, 0.5, -resizeHandleSize/2))
	createResizeHandle("Left", UDim2.new(0, -resizeHandleSize/2, 0.5, -resizeHandleSize/2))
	createResizeHandle("Bottom", UDim2.new(0.5, -resizeHandleSize/2, 1, -resizeHandleSize/2))
	createResizeHandle("Top", UDim2.new(0.5, -resizeHandleSize/2, 0, -resizeHandleSize/2))

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newWidth = startSize.X
			local newHeight = startSize.Y
			local newX = startPos.X
			local newY = startPos.Y

			if resizeDir == "BottomRight" then
				newWidth = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
				newHeight = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
			elseif resizeDir == "BottomLeft" then
				local widthChange = math.clamp(startSize.X - delta.X, minSize.X, maxSize.X) - startSize.X
				newWidth = startSize.X + widthChange
				newX = startPos.X - widthChange
				newHeight = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
			elseif resizeDir == "TopRight" then
				newWidth = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
				local heightChange = math.clamp(startSize.Y - delta.Y, minSize.Y, maxSize.Y) - startSize.Y
				newHeight = startSize.Y + heightChange
				newY = startPos.Y - heightChange
			elseif resizeDir == "TopLeft" then
				local widthChange = math.clamp(startSize.X - delta.X, minSize.X, maxSize.X) - startSize.X
				newWidth = startSize.X + widthChange
				newX = startPos.X - widthChange
				local heightChange = math.clamp(startSize.Y - delta.Y, minSize.Y, maxSize.Y) - startSize.Y
				newHeight = startSize.Y + heightChange
				newY = startPos.Y - heightChange
			elseif resizeDir == "Right" then
				newWidth = math.clamp(startSize.X + delta.X, minSize.X, maxSize.X)
			elseif resizeDir == "Left" then
				local widthChange = math.clamp(startSize.X - delta.X, minSize.X, maxSize.X) - startSize.X
				newWidth = startSize.X + widthChange
				newX = startPos.X - widthChange
			elseif resizeDir == "Bottom" then
				newHeight = math.clamp(startSize.Y + delta.Y, minSize.Y, maxSize.Y)
			elseif resizeDir == "Top" then
				local heightChange = math.clamp(startSize.Y - delta.Y, minSize.Y, maxSize.Y) - startSize.Y
				newHeight = startSize.Y + heightChange
				newY = startPos.Y - heightChange
			end

			Container.Size = UDim2.new(0, newWidth, 0, newHeight)
			Container.Position = UDim2.new(0.5, newX, 0.5, newY)
			size = Vector2.new(newWidth, newHeight)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = false
			resizeDir = nil
		end
	end)

	if isMobile or isTablet then
		workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
			local newSize = getMobileSize()
			size = newSize
